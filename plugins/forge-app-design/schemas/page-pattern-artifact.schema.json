{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://forge.local/forge-app-design/page-pattern-artifact.schema.json",
  "title": "forge-app-design page-pattern artifact",
  "type": "object",
  "required": ["version", "archetypeId", "patterns"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "archetypeId": { "type": "string", "minLength": 1 },
    "sourceReferences": { "type": "array", "items": { "type": "string" }, "default": [] },
    "patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "routeRole",
          "layoutIntent",
          "decisionQuestion",
          "primaryDataObject",
          "businessDensity",
          "expectedForgeComponents"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "routeRole": { "type": "string", "minLength": 1 },
          "layoutIntent": { "type": "string", "minLength": 1 },
          "decisionQuestion": { "type": "string", "minLength": 1 },
          "primaryDataObject": { "type": "string", "minLength": 1 },
          "kpiCards": { "type": "array", "items": { "type": "string" }, "default": [] },
          "tableColumns": { "type": "array", "items": { "type": "string" }, "default": [] },
          "detailSections": { "type": "array", "items": { "type": "string" }, "default": [] },
          "drawerActions": { "type": "array", "items": { "type": "string" }, "default": [] },
          "workflowStates": { "type": "array", "items": { "type": "string" }, "default": [] },
          "emptyStateCopy": { "type": "string" },
          "requiredVisibleText": { "type": "array", "items": { "type": "string" }, "default": [] },
          "businessDensity": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "visualBaseline": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "typography": { "type": "array", "items": { "type": "string" }, "default": [] },
              "density": { "type": "array", "items": { "type": "string" }, "default": [] },
              "spacing": { "type": "array", "items": { "type": "string" }, "default": [] },
              "borders": { "type": "array", "items": { "type": "string" }, "default": [] },
              "profileRegion": { "type": "array", "items": { "type": "string" }, "default": [] },
              "tableFirstViewport": { "type": "array", "items": { "type": "string" }, "default": [] },
              "rightRail": { "type": "array", "items": { "type": "string" }, "default": [] }
            }
          },
          "linksOut": { "type": "array", "items": { "type": "string" }, "default": [] },
          "expectedForgeComponents": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "forbiddenShortcuts": { "type": "array", "items": { "type": "string" }, "default": [] }
        }
      }
    }
  }
}
